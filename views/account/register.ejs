<h1><%= title %></h1>

<%- messages() %>

<form action="/account/register" method="post">
    <label>First Name</label>
    <input type="text" name="account_firstname" required>

    <label>Last Name</label>
    <input type="text" name="account_lastname" required>

    <label>Email</label>
    <input type="email" name="account_email" required placeholder="Enter a valid email">

    <label for="accountPassword">Password:</label>
    <span>
        Passwords must be at least 12 characters and contain:
        1 number, 1 uppercase letter, and 1 special character
    </span>
    <input 
        type="password" 
        name="account_password" 
        id="accountPassword" 
        required 
        pattern="^(?=.*\d)(?=.*[a-z])(?=.*[A-Z])(?=.*[^a-zA-Z0-9])(?!.*\s).{12,}$"
    >

  <button type="submit">Register</button>
</form>
